{
  "name": "qvstime",
  "displayName": "qVStime",
  "description": "A super simple VSC/odium plugin to show some more detailed Hackatime stats for a user as a sidebar!",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/qwikster/qvstime"
  },
  "engines": {
    "vscode": "^1.8.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qvstime",
          "title": "qVStime",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "qvstime": [
        {
          "type": "webview",
          "id": "qvstime.sidebarView",
          "name": "qVStime"
        }
      ]
    },
    "activationEvents": [
      "onView:qvstime.sidebarView"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.8.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
